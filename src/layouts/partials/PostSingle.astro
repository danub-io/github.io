---
import Share from "@/components/Share.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import dateFormat from "@/lib/utils/dateFormat";
import similerItems from "@/lib/utils/similarItems";
import { humanize, markdownify, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import { render } from "astro:content";
import placeholder from "@/assets/images/placeholder.png";
import config from "@/config/config.json";

const allAuthors = await getSinglePage("authors");
const posts = await getSinglePage("posts");
const { post } = Astro.props;
const similarPosts = similerItems(post, posts, post.id);
const { Content } = await render(post);
const { title, description, authors, image, image_alt, date, tags } = post.data;
const recommendedPosts = [
  ...similarPosts,
  ...posts.filter(
    (p) => p.id !== post.id && !similarPosts.find((sp) => sp.id === p.id),
  ),
].slice(0, 6);

const { support_url } = config.params;
---

<section class="pt-10 md:pt-16 pb-16 md:pb-[68px] bg-white">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <article class="w-full flex flex-col">
      <div class="w-full text-center mb-6 md:mb-12">
        <div class="flex items-center justify-center flex-wrap mb-4">
          {
            tags && tags.length > 0 && (
              <a
                href={`/tags/${slugify(tags[0])}`}
                class="text-gray-500 font-secondary font-bold text-xs tracking-[0.2em] uppercase hover:text-black transition"
              >
                {humanize(tags[0])}
              </a>
            )
          }
        </div>

        <h1
          set:html={markdownify(title)}
          class="font-primary text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-black mb-6 leading-[1.1] tracking-tight"
        />

        {
          description && (
            <p class="text-xl md:text-2xl text-gray-700 font-secondary font-light mx-auto leading-relaxed mb-6">
              {description}
            </p>
          )
        }

        <div
          class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-4 text-sm font-secondary text-gray-600 mt-6 border-t border-gray-300 pt-4 mx-auto"
        >
          <div class="flex items-center space-x-2">
            <span
              class="font-medium text-gray-600 uppercase tracking-widest text-[10px]"
              >Por</span
            >
            {
              allAuthors
                .filter((author) =>
                  authors
                    .map((a: string) => slugify(a))
                    .includes(slugify(author.data.title)),
                )
                .map((author, i) => (
                  <a
                    href={`/autores/${slugify(author.id)}`}
                    class="font-medium text-gray-600 uppercase tracking-widest text-[10px] hover:underline"
                  >
                    {author.data.title}
                    {i < authors.length - 1 ? "," : ""}
                  </a>
                ))
            }
          </div>
          <span class="hidden md:block text-gray-400">•</span>
          <time
            class="font-medium text-gray-600 uppercase tracking-widest text-[10px]"
            >{dateFormat(date)}</time
          >
        </div>
      </div>

      {
        (image || placeholder) && (
          <div class="w-full max-w-5xl mb-6 md:mb-12">
            <Image
              width={1000}
              height={562}
              widths={[400, 662, 1000]}
              sizes="(max-width: 1024px) 95vw, 662px"
              loading="eager"
              fetchpriority="high"
              src={image || placeholder}
              alt={image_alt || title}
              class="object-cover aspect-[21/9] sm:aspect-[16/9] w-full border border-gray-300 grayscale-[20%]"
              format="webp"
            />
            {image_alt && (
              <p class="text-center text-xs text-gray-500 font-secondary italic mt-3">
                {image_alt}
              </p>
            )}
          </div>
        )
      }

      <div class="w-full max-w-5xl sm:px-0">
        <div
          class="content text-lg md:text-xl leading-loose text-gray-800 font-secondary font-light"
        >
          <Content />
        </div>

        <div
          class="pt-[50px] pb-6 mt-[60px] mb-10 text-center border-t border-gray-200"
        >
          <h2
            class="font-primary text-2xl md:text-3xl font-bold text-black mb-4 uppercase tracking-widest"
          >
            Apoie a Missão Editorial do GospelReads
          </h2>
          <p
            class="text-gray-700 mb-8 text-base font-secondary max-w-xl mx-auto leading-relaxed"
          >
            O <strong>GospelReads</strong> é uma iniciativa editorial mantida por
            leitores que valorizam a profundidade teológica e literária. Se esta edição
            acrescentou valor à sua vida, considere fazer parte do nosso clube de
            apoiadores.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <a
              href={support_url}
              class="inline-flex items-center justify-center bg-black border border-black text-white px-5 py-2.5 hover:bg-gray-800 font-bold text-[11px] tracking-widest uppercase transition-colors"
            >
              Tornar-se Apoiador
            </a>
            <a
              href="/#livros"
              class="inline-flex items-center justify-center bg-white border border-black text-black px-5 py-2.5 hover:bg-gray-100 font-bold text-[11px] tracking-widest uppercase transition-colors"
            >
              Nossas Publicações
            </a>
          </div>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-8 mt-6 pt-8 pb-6 border-t border-b border-gray-200"
        >
          <div class="flex flex-wrap items-center justify-center gap-2 mb-2">
            {
              tags && tags.length > 0 && (
                <div class="text-[10px] font-secondary font-bold text-gray-600 uppercase tracking-widest mr-1">
                  Tópico:
                </div>
              )
            }
            {
              tags &&
                tags.length > 0 &&
                tags.map((tag: any) => (
                  <a
                    href={`/tags/${slugify(tag)}`}
                    class="inline-block border border-gray-300 px-3 py-1 font-bold text-gray-600 text-[10px] uppercase tracking-widest hover:text-black hover:border-black transition"
                  >
                    {humanize(tag)}
                  </a>
                ))
            }
          </div>
          <Share
            className="social-share opacity-80 hover:opacity-100 transition"
            title={title}
            description={description}
            slug={post.id}
          />
        </div>
      </div>
    </article>
  </div>
</section>

<section class="pb-10 mt-0">
  <div class="max-w-5xl mx-auto px-4 sm:px-6">
    <div class="mb-10 text-center">
      <h2
        class="font-primary text-xl md:text-2xl font-bold text-black uppercase tracking-widest"
      >
        Leia mais ...
      </h2>
      <div class="w-24 h-px bg-black mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8">
      {
        recommendedPosts.map((p) => (
          <article class="flex flex-col">
            <a
              href={`/blog/${p.id}`}
              class="block w-full overflow-hidden border border-gray-200 mb-4 group"
            >
              <Image
                loading="lazy"
                src={p.data.image || placeholder}
                alt={p.data.image_alt || p.data.title}
                width={600}
                height={400}
                class="w-full aspect-[3/2] object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-500"
                format="webp"
              />
            </a>
            <div>
              <div class="flex items-center space-x-2 mb-2 text-[10px] font-secondary font-bold text-gray-500 uppercase tracking-widest">
                {p.data.tags && p.data.tags.length > 0 && (
                  <a
                    href={`/tags/${slugify(p.data.tags[0])}`}
                    class="hover:text-black"
                  >
                    {humanize(p.data.tags[0])}
                  </a>
                )}
              </div>
              <a href={`/blog/${p.id}`} class="block group">
                <h2 class="font-primary text-xl font-bold text-black group-hover:text-gray-600 transition-colors leading-tight">
                  {p.data.title}
                </h2>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
