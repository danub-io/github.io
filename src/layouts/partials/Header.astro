---
import menu from "@/config/menu.json";
import { IoSearch, IoClose } from "react-icons/io5";

export interface ChildNavigationLink {
  name: string;
  url: string;
}
import config from "@/config/config.json";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { humanize } from "@/lib/utils/textConverter";

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}
const { main }: { main: NavigationLink[] } = menu;
const { support_url } = config.params;

const tags = await getTaxonomy("posts", "tags");
const sortedTags = tags
  .map((tag) => ({
    name: humanize(tag),
    url: `/tags/${tag}`,
  }))
  .sort((a, b) => a.name.localeCompare(b.name));
---

<header class="w-full z-40 bg-white mb-6 relative">
  <div class="max-w-5xl mx-auto px-4 md:px-8">
    <!-- Top Bar with Date -->
    <div
      class="flex justify-between items-center py-2 border-b border-gray-300 text-[10px] sm:text-xs uppercase tracking-widest text-gray-500 font-secondary"
    >
      <span></span>
      <span id="current-date">
        {
          new Intl.DateTimeFormat("pt-BR", {
            weekday: "long",
            year: "numeric",
            month: "long",
            day: "numeric",
          }).format(new Date())
        }
      </span>
    </div>

    <!-- Masthead -->
    <div class="w-full flex flex-col items-center justify-center py-6 sm:py-8">
      <a
        href="/"
        class="text-5xl sm:text-6xl md:text-7xl lg:text-[5.5rem] font-primary font-bold text-black transition hover:opacity-80 leading-none tracking-tight text-center"
      >
        GospelReads.
      </a>
      <p
        class="text-xs sm:text-sm italic text-gray-600 mt-2 sm:mt-4 font-primary"
      >
        Evangelho, Mente e Vocação
      </p>
    </div>

    <!-- Navigation -->
    <div class="w-full border-t border-black relative mt-1">
      <div class="absolute -top-[3px] left-0 w-full border-t border-black">
      </div>
      <nav
        class="w-full flex justify-between items-center py-3 border-b border-black"
        id="main-nav"
      >
        <div id="nav-content" class="w-full flex justify-between items-center">
          <div
            class="flex-1 flex justify-center md:justify-start space-x-6 overflow-x-auto no-scrollbar"
          >
            {
              main.map((menu) => (
                <a
                  href={menu.url}
                  class="text-xs sm:text-sm font-secondary font-bold text-dark hover:text-gray-500 uppercase tracking-widest whitespace-nowrap"
                >
                  {menu.name}
                </a>
              ))
            }
          </div>

          <div
            class="hidden md:flex items-center space-x-5 ml-4 border-l border-gray-300 pl-4"
          >
            <a
              href={support_url}
              class="text-xs font-bold tracking-widest uppercase text-dark hover:text-gray-500 transition"
            >
              Apoiar
            </a>
            <button
              class="text-dark hover:text-gray-500 transition cursor-pointer p-1"
              aria-label="search"
              data-search-trigger
            >
              <IoSearch className="text-[20px]" />
            </button>
          </div>

          <!-- Mobile Controls -->
          <div class="flex md:hidden items-center space-x-3 ml-auto pl-4">
            <button
              class="text-dark hover:text-gray-500 transition cursor-pointer p-1"
              aria-label="search"
              data-search-trigger
            >
              <IoSearch className="text-[20px]" />
            </button>
            <button
              id="mobile-menu-btn"
              class="cursor-pointer text-dark focus:outline-none p-1 z-50 relative"
              aria-label="Toggle Menu"
            >
              <svg
                id="icon-open"
                class="w-6 h-6 transition-opacity duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path>
              </svg>
              <svg
                id="icon-close"
                class="w-6 h-6 hidden transition-opacity duration-300"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>

        <div id="search-bar" class="hidden w-full">
          <form
            action="/search"
            method="GET"
            class="relative flex items-center p-1 sm:p-2 w-full"
          >
            <label for="search-input" class="sr-only">Buscar</label>
            <span
              class="absolute left-4 sm:left-6 text-gray-400 text-xl sm:text-2xl"
              ><IoSearch /></span
            >
            <input
              class="w-full bg-transparent py-4 sm:py-6 pl-12 pr-12 sm:pl-16 sm:pr-16 text-lg sm:text-2xl font-primary text-dark placeholder:text-gray-400 border-0 focus:ring-0 outline-none rounded-none"
              placeholder="Buscar postagens, artigos..."
              type="text"
              name="q"
              id="search-input"
              autocomplete="off"
            />
            <button
              type="button"
              class="absolute right-4 sm:right-6 text-gray-400 hover:text-dark transition cursor-pointer"
              id="search-bar-close"
              ><IoClose className="text-2xl sm:text-3xl" /></button
            >
          </form>
        </div>
      </nav>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div
    id="mobile-menu-dropdown"
    class="absolute top-full left-0 w-full bg-white border-b-4 border-black shadow-xl flex-col px-6 py-8 hidden transform origin-top transition-all duration-300 z-50 overflow-y-auto max-h-[80vh]"
  >
    <div class="max-w-5xl mx-auto w-full space-y-6 text-center">
      {
        sortedTags.map((tag) => (
          <a
            href={tag.url}
            class="block text-xl font-primary font-bold text-dark hover:text-gray-500"
          >
            {tag.name}
          </a>
        ))
      }
      <div class="pt-6 border-t border-gray-200">
        <a
          href={support_url}
          class="block text-center w-full sm:w-auto sm:inline-flex items-center justify-center bg-white border border-black text-dark px-5 py-3 hover:bg-black hover:text-white text-sm font-bold tracking-widest uppercase transition-all duration-300 shadow-none"
        >
          Apoiar a Missão
        </a>
      </div>
    </div>
  </div>
</header>

<script is:inline>
  (function () {
    let onKeyDown;

    function updateDate() {
      const dateEl = document.getElementById("current-date");
      if (dateEl) {
        const now = new Date();
        const locale = "pt-BR";
        const formattedDate = new Intl.DateTimeFormat(locale, {
          weekday: "long",
          year: "numeric",
          month: "long",
          day: "numeric",
        }).format(now);
        dateEl.textContent = formattedDate;
      }
    }

    function initNav() {
      updateDate();
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu-dropdown");
      const iconOpen = document.getElementById("icon-open");
      const iconClose = document.getElementById("icon-close");

      if (btn && menu) {
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);
        newBtn.addEventListener("click", function () {
          menu.classList.toggle("hidden");
          menu.classList.toggle("flex");
          iconOpen.classList.toggle("hidden");
          iconClose.classList.toggle("hidden");
        });

        document.addEventListener("click", function (event) {
          if (
            !menu.classList.contains("hidden") &&
            !menu.contains(event.target) &&
            !newBtn.contains(event.target)
          ) {
            menu.classList.add("hidden");
            menu.classList.remove("flex");
            iconOpen.classList.remove("hidden");
            iconClose.classList.add("hidden");
          }
        });
      }

      const searchTriggers = document.querySelectorAll("[data-search-trigger]");
      const searchBar = document.getElementById("search-bar");
      const navContent = document.getElementById("nav-content");
      const closeSearchBar = document.getElementById("search-bar-close");
      const searchInput = document.getElementById("search-input");

      function openSearch(e) {
        e.preventDefault();
        if (navContent) {
          navContent.classList.add("hidden");
        }
        if (searchBar) {
          searchBar.classList.remove("hidden");
          searchBar.classList.add("flex");
        }
        if (searchInput) searchInput.focus();
      }

      function closeSearch() {
        if (searchBar) {
          searchBar.classList.add("hidden");
          searchBar.classList.remove("flex");
        }
        if (navContent) {
          navContent.classList.remove("hidden");
        }
      }

      searchTriggers.forEach(function (t) {
        t.addEventListener("click", openSearch);
      });
      if (closeSearchBar) closeSearchBar.addEventListener("click", closeSearch);

      if (onKeyDown) {
        document.removeEventListener("keydown", onKeyDown);
      }
      onKeyDown = function (e) {
        if (e.key === "Escape" && !searchBar.classList.contains("hidden")) {
          closeSearch();
        }
      };
      document.addEventListener("keydown", onKeyDown);
    }

    initNav();
    document.addEventListener("astro:page-load", initNav);
  })();
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
