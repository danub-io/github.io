---
import Base from "@/layouts/Base.astro";
import { getTaxonomy } from "@/lib/taxonomyParser.astro";
import { humanize, slugify } from "@/lib/utils/textConverter";

const tags = await getTaxonomy("posts", "tags");
---

<Base title="Temas e Trilhas de Estudo - GospelReads">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 mb-16 min-h-[60vh]">
    <div class="w-full text-center border-b border-black pb-8 mb-8 relative">
      <div class="absolute -bottom-[3px] left-0 w-full border-b border-black">
      </div>
      <h1
        class="font-primary text-4xl sm:text-5xl md:text-6xl font-bold text-black mb-4 leading-tight tracking-tight"
      >
        Temas e Trilhas
      </h1>
      <p class="text-gray-600 font-secondary italic font-light tracking-wide">
        Explore nosso conteúdo organizado por tópicos e categorias editoriais.
      </p>
    </div>

    <ul
      class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4"
    >
      {
        tags.map((tag) => (
          <li>
            <a
              href={`/tags/${slugify(tag)}`}
              class="flex items-center justify-center border border-gray-300 text-black px-4 py-3 hover:bg-black hover:text-white font-bold text-xs tracking-widest uppercase transition-colors"
            >
              {humanize(tag)}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Base>
