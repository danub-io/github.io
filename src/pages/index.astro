---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import placeholder from "@/assets/images/placeholder.png";
import capaPrincipalMandamento from "@/assets/images/capa-principal-mandamento.jpg";
import capaGestaoPessoas from "@/assets/images/capa-gestao-pessoas.png";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const latestPost = sortedPosts[0];
const recentPosts = sortedPosts.slice(1, 5);
---

<Base>
  {latestPost && (
    <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-6 pb-10 sm:pt-10 sm:pb-16">
        <article class="group flex flex-col md:flex-row bg-white border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-500 overflow-hidden relative">
            <a href={`/blog/${latestPost.id}`} class="block w-full md:w-3/5 overflow-hidden relative order-1">
                <div class="absolute inset-0 bg-primary opacity-0 group-hover:opacity-10 transition-opacity duration-500 z-10"></div>
                <Image
                    src={latestPost.data.image || placeholder}
                    alt={latestPost.data.title}
                    width={800}
                    height={500}
                    loading="eager"
                    fetchpriority="high"
                    class="w-full h-[250px] sm:h-[350px] md:h-full object-cover group-hover:scale-105 transition-transform duration-700"
                    format="webp"
                />
            </a>
            
            <div class="w-full md:w-2/5 p-6 sm:p-8 md:p-10 flex flex-col justify-center order-2 bg-white z-20">
                <div class="flex items-center space-x-2 mb-4">
                    {latestPost.data.tags && latestPost.data.tags.length > 0 && (
                        <a href={`/tags/${slugify(latestPost.data.tags[0])}`} class="text-dark text-[11px] sm:text-xs font-bold uppercase tracking-wider hover:text-primary transition-colors">
                            {humanize(latestPost.data.tags[0])}
                        </a>
                    )}
                    <span class="text-slate-300 text-xs">•</span>
                    <time class="text-slate-500 text-[11px] sm:text-xs font-medium">{dateFormat(latestPost.data.date)}</time>
                </div>
                
                <a href={`/blog/${latestPost.id}`} class="block mb-4">
                    <h2 class="font-primary text-2xl sm:text-3xl lg:text-4xl font-bold text-dark group-hover:text-primary transition-colors leading-tight">
                        {latestPost.data.title}
                    </h2>
                </a>
                
                {latestPost.data.description && (
                    <p class="text-slate-500 text-sm sm:text-base font-light mb-8 line-clamp-3 leading-relaxed">
                        {latestPost.data.description}
                    </p>
                )}
                
                <a href={`/blog/${latestPost.id}`} class="inline-flex items-center group/btn self-start mt-auto">
                    <span class="bg-white border border-dark text-dark group-hover/btn:text-white px-8 py-3.5 text-xs font-bold tracking-[0.2em] uppercase transition-all duration-300 group-hover/btn:bg-dark shadow-sm">
                        Ler Artigo
                    </span>
                    <span class="bg-dark text-white p-3.5 transition-transform duration-300 group-hover/btn:translate-x-1">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                    </span>
                </a>
            </div>
        </article>
    </section>
  )}

  <section id="ensaios" class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-20">
      <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 pb-6 border-b border-gray-200">
          <div>
              <h2 class="font-primary text-3xl sm:text-4xl font-bold text-dark">Reflexões que Transformam</h2>
              <p class="text-text mt-2">Artigos, postagens e estudos profundos para nutrir sua fé e afiar sua mente.</p>
          </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-12">
          {recentPosts.map((post) => (
              <article class="group flex flex-col gap-5 items-start">
                  <a href={`/blog/${post.id}`} class="block w-full overflow-hidden rounded-none shadow-sm relative group-hover:shadow-md transition-shadow duration-300">
                      <div class="absolute inset-0 bg-primary opacity-0 group-hover:opacity-10 transition-opacity duration-300 z-10"></div>
                      <Image
                          src={post.data.image || placeholder}
                          alt={post.data.title}
                          width={800}
                          height={450}
                          widths={[400, 600, 800]}
                          sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 450px"
                          loading="lazy"
                          class="w-full aspect-[16/9] object-cover group-hover:scale-105 transition-transform duration-500"
                          format="webp"
                      />
                  </a>
 
                  <div class="flex-1 w-full">
                      <div class="flex items-center space-x-2 mb-2">
                          {post.data.tags && post.data.tags.length > 0 && (
                              <a href={`/tags/${slugify(post.data.tags[0])}`} class="text-dark text-[11px] font-bold uppercase tracking-wider hover:text-primary transition-colors">
                                  {humanize(post.data.tags[0])}
                              </a>
                          )}
                          <span class="text-slate-300 text-xs">•</span>
                          <time class="text-slate-500 text-[11px] font-medium">{dateFormat(post.data.date)}</time>
                      </div>
                 
                      <a href={`/blog/${post.id}`} class="block">
                          <h3 class="font-primary text-2xl sm:text-3xl font-bold text-dark group-hover:text-slate-600 transition-colors mb-2 leading-tight">
                              {post.data.title}
                          </h3>
                      </a>
                  </div>
              </article>
          ))}
      </div>
      
      <div class="mt-10 text-center">
          <a href="/arquivo" class="inline-block bg-white border-2 border-dark text-dark px-10 py-4 hover:bg-dark hover:text-white font-bold text-sm tracking-widest uppercase transition-all duration-300">
              Explorar o Arquivo
          </a>
      </div>
  </section>

  <section id="livros" class="max-w-5xl mx-auto px-4 sm:px-6 pt-12 md:pt-16 pb-24 md:pb-32">
      <div class="flex flex-col mb-16 md:mb-20 text-center">
          <h2 class="font-primary text-3xl sm:text-4xl md:text-5xl font-bold text-dark tracking-tight">A Biblioteca do Discipulado</h2>
          <p class="text-slate-500 mt-4 max-w-2xl mx-auto font-light text-base md:text-lg">Manuais práticos e obras teológicas para sua jornada espiritual e profissional. Pague o quanto quiser.
O conhecimento do Reino não deve ter barreiras.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10">
          
          <a href="#" class="group flex flex-col sm:flex-row gap-6 md:gap-10 lg:gap-8 bg-white p-6 md:p-10 lg:p-8 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-500 items-center sm:items-start relative overflow-hidden">
              <div class="w-48 sm:w-44 md:w-56 lg:w-40 shrink-0 relative shadow-md group-hover:-translate-y-2 group-hover:shadow-2xl transition-all duration-500 ease-out z-10">
                <div class="absolute inset-0 bg-gradient-to-r from-black/10 via-transparent to-transparent z-10 pointer-events-none"></div>
                <div class="absolute left-0 top-0 bottom-0 w-[1px] bg-white/30 z-20 pointer-events-none"></div>
                <Image
                    src={capaPrincipalMandamento}
                    alt="O Principal Mandamento"
                    width={300}
                    height={450}
                    class="w-full h-auto object-contain block"
                />
              </div>
              <div class="flex flex-col justify-center text-center sm:text-left h-full z-10 w-full min-w-0">
                  <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-slate-500 mb-2 lg:mb-3 block">Lançamento</span>
                  <h3 class="font-primary text-2xl md:text-3xl lg:text-2xl font-bold text-dark mb-3 lg:mb-4 leading-snug group-hover:text-slate-700 transition-colors duration-300 break-words">O Principal Mandamento</h3>
                  <p class="text-sm md:text-base lg:text-sm text-slate-500 font-light mb-6 lg:mb-8 line-clamp-3 leading-relaxed">O Evangelho que confronta nosso ego e restaura nossa essência.
Uma jornada de volta ao coração de Deus, indo muito além da religiosidade superficial.</p>
                  <span class="inline-block bg-white border border-dark text-dark group-hover:text-white group-hover:bg-dark px-8 py-3.5 text-xs font-bold tracking-[0.2em] uppercase transition-all duration-300 self-center sm:self-start mt-auto shadow-md">
                      Ler Agora
                  </span>
              </div>
          </a>

          <a href="#" class="group flex flex-col sm:flex-row gap-6 md:gap-10 lg:gap-8 bg-white p-6 md:p-10 lg:p-8 border border-gray-100 shadow-sm hover:shadow-xl transition-all duration-500 items-center sm:items-start relative overflow-hidden">
              <div class="w-48 sm:w-44 md:w-56 lg:w-40 shrink-0 relative shadow-md group-hover:-translate-y-2 group-hover:shadow-2xl transition-all duration-500 ease-out z-10">
                <div class="absolute inset-0 bg-gradient-to-r from-black/10 via-transparent to-transparent z-10 pointer-events-none"></div>
                <div class="absolute left-0 top-0 bottom-0 w-[1px] bg-white/30 z-20 pointer-events-none"></div>
                <Image
                    src={capaGestaoPessoas}
                    alt="Gestão de Pessoas"
                    width={300}
                    height={450}
                    class="w-full h-auto object-contain block"
                />
              </div>
              <div class="flex flex-col justify-center text-center sm:text-left h-full z-10 w-full min-w-0">
                  <span class="text-[10px] md:text-xs font-bold uppercase tracking-[0.2em] text-slate-500 mb-2 lg:mb-3 block">Business & Fé</span>
                  <h3 class="font-primary text-2xl md:text-3xl lg:text-2xl font-bold text-dark mb-3 lg:mb-4 leading-snug group-hover:text-slate-700 transition-colors duration-300 break-words">Gestão de Pessoas</h3>
                  <p class="text-sm md:text-base lg:text-sm text-slate-500 font-light mb-6 lg:mb-8 line-clamp-3 leading-relaxed">Liderança com propósito.
Desbloqueie o potencial humano alinhando a excelência profissional do mercado às verdades imutáveis da administração cristã.</p>
                  <span class="inline-block bg-white border border-dark text-dark group-hover:text-white group-hover:bg-dark px-8 py-3.5 text-xs font-bold tracking-[0.2em] uppercase transition-all duration-300 self-center sm:self-start mt-auto shadow-md">
                      Ler Agora
                  </span>
              </div>
          </a>

      </div>
  </section>
</Base>