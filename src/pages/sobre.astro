---
import Base from "@/layouts/Base.astro";
import { Image } from "astro:assets";
import { getEntry, render } from "astro:content";
import { markdownify } from "@/lib/utils/textConverter";

const about = await getEntry("about", "-index");
if (!about) {
  return Astro.redirect("/404");
}
const { Content } = await render(about);
const { title, meta_title, image } = about.data;
const description = (about.data as any).description || meta_title || "";
---

<Base title={title} meta_title={meta_title} description={description}>
  <section class="max-w-4xl mx-auto px-4 sm:px-6 mb-20 min-h-[60vh]">
    <div class="flex flex-col gap-12 items-start w-full">
      <div class="w-full text-center border-b border-black pb-8 mb-8 relative">
        <div class="absolute -bottom-[3px] left-0 w-full border-b border-black">
        </div>
        <h1
          set:html={markdownify(title)}
          class="font-primary text-4xl sm:text-5xl md:text-6xl font-bold text-black mb-4 leading-tight tracking-tight"
        />
        <p class="text-gray-600 font-secondary italic font-light tracking-wide">
          A Missão e o Propósito do GospelReads
        </p>
      </div>

      <div class="flex flex-col md:flex-row gap-8 sm:gap-12 items-start w-full">
        {
          image && (
            <div class="w-full md:w-1/3 shrink-0">
              <div class="border border-gray-300 p-2 bg-white">
                <Image
                  src={image}
                  width={600}
                  height={600}
                  alt={title}
                  class="w-full h-auto object-cover grayscale-[20%]"
                />
              </div>
            </div>
          )
        }

        <div class="flex-1 w-full mt-4 md:mt-0">
          <div
            class="content text-lg md:text-xl leading-loose text-gray-800 font-secondary font-light"
          >
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
