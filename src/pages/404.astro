---
import Base from "@/layouts/Base.astro";
---

<Base title="Página Não Encontrada">
  <section class="py-6">
    <div class="max-w-[1000px] px-4 mx-auto">
      <div class="flex h-[40vh] items-center justify-center">
        <div class="text-center">
          <h1 class="h2 md:h1 mb-4">Error 404</h1>
          <div class="content">
            <p>Página Não Encontrada</p>
          </div>
          <a
            href="/"
            class="inline-block border border-gray-300 px-6 py-2 font-semibold transition cursor-pointer bg-white text-dark hover:bg-gray-50 mt-8"
            >Voltar para o Início</a
          >
        </div>
      </div>
    </div>
  </section>
</Base>
