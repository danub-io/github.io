---
import Base from "@/layouts/Base.astro";
---

<Base title="Página Não Encontrada">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 mb-32">
    <div class="flex h-[50vh] items-center justify-center">
      <div class="text-center border-t-2 border-b-2 border-black py-12 px-8">
        <h1 class="font-primary text-6xl md:text-8xl font-bold text-black mb-4">
          404
        </h1>
        <div class="content mb-8">
          <p class="text-xl font-secondary italic text-gray-600">
            Página Não Encontrada
          </p>
          <p class="text-sm text-gray-500 mt-2">
            O artigo que você procura pode ter sido movido ou removido de nossas
            edições.
          </p>
        </div>
        <a
          href="/"
          class="inline-block bg-black text-white px-8 py-3 font-bold text-xs uppercase tracking-[0.2em] transition-colors hover:bg-gray-800"
          >Voltar para a Capa</a
        >
      </div>
    </div>
  </section>
</Base>
