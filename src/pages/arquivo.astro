---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { sortByDate } from "@/lib/utils/sortFunctions";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, slugify } from "@/lib/utils/textConverter";
import { Image } from "astro:assets";
import placeholder from "@/assets/images/placeholder.png";

const posts = await getSinglePage("posts");
const sortedPosts = sortByDate(posts);
const INITIAL_LOAD = 8;
---

<Base title="Arquivo - GospelReads">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 mb-16">
    <div class="border-b-[4px] border-black pb-6 mb-10">
      <h1
        class="font-primary text-4xl sm:text-5xl font-bold text-black tracking-tight"
      >
        Acervo Literário
      </h1>
      <p class="text-gray-800 mt-3 text-lg font-secondary font-light max-w-2xl">
        Edições passadas, estudos aprofundados e reflexões que moldaram a nossa
        jornada.
      </p>
    </div>

    <div
      id="archive-container"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-0 border-l border-gray-300"
    >
      {
        sortedPosts.map((post, index) => (
          <article
            class={`archive-item ${index >= INITIAL_LOAD ? "hidden" : "flex"} flex-col p-6 border-r border-b border-gray-300 group`}
          >
            <div class="flex items-center space-x-2 mb-3 text-[10px] font-secondary font-bold text-gray-500 uppercase tracking-widest">
              {post.data.tags && post.data.tags.length > 0 && (
                <a
                  href={`/tags/${slugify(post.data.tags[0])}`}
                  class="hover:text-black transition"
                >
                  {humanize(post.data.tags[0])}
                </a>
              )}
              <span>•</span>
              <time>{dateFormat(post.data.date)}</time>
            </div>

            <a href={`/blog/${post.id}`} class="block group mb-4">
              <h3 class="font-primary text-2xl font-bold text-black group-hover:text-gray-600 transition-colors leading-tight">
                {post.data.title}
              </h3>
            </a>

            <a
              href={`/blog/${post.id}`}
              class="block w-full overflow-hidden border border-gray-200 mb-4 group ring-1 ring-gray-100"
            >
              <Image
                src={post.data.image || placeholder}
                alt={post.data.title}
                width={600}
                height={400}
                loading="lazy"
                class="w-full aspect-[3/2] object-cover grayscale-[30%] group-hover:grayscale-0 transition-all duration-500"
                format="webp"
              />
            </a>

            {post.data.description && (
              <p class="text-gray-700 text-sm font-secondary line-clamp-3 leading-relaxed">
                {post.data.description}
              </p>
            )}
          </article>
        ))
      }
    </div>

    {
      sortedPosts.length > INITIAL_LOAD && (
        <div
          id="infinite-scroll-trigger"
          class="w-full h-32 flex items-center justify-center mt-8"
        >
          <div class="animate-pulse flex space-x-3 items-center">
            <span class="w-2 h-2 bg-gray-300 rounded-none" />
            <span class="w-2 h-2 bg-gray-300 rounded-none" />
            <span class="w-2 h-2 bg-gray-300 rounded-none" />
          </div>
        </div>
      )
    }
  </section>

  <script is:inline>
    function initInfiniteScroll() {
      const trigger = document.getElementById("infinite-scroll-trigger");
      const hiddenPosts = Array.from(
        document.querySelectorAll(".archive-item.hidden"),
      );
      const batchSize = 6;

      if (!trigger || hiddenPosts.length === 0) return;

      const observer = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting) {
            const nextBatch = hiddenPosts.splice(0, batchSize);
            nextBatch.forEach((post) => {
              post.classList.remove("hidden");
              post.classList.add("flex");
              post.style.opacity = "0";
              post.style.transition = "opacity 0.5s ease-in-out";
              setTimeout(() => (post.style.opacity = "1"), 50);
            });
            if (hiddenPosts.length === 0) {
              observer.disconnect();
              trigger.style.display = "none";
            }
          }
        },
        { rootMargin: "300px" },
      );

      observer.observe(trigger);
    }
    document.addEventListener("astro:page-load", initInfiniteScroll);
    initInfiniteScroll();
  </script>
</Base>
